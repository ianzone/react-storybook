{
  "name": "react-storybook-template",
  "version": "0.0.0",
  "description": "react storybook template",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "style": "./dist/style.css",
  "homepage": "https://github.com/ianzone/react-storybook#readme",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "dev:cc": "storybook dev -p 6006 --force-build-preview",
    "build": "tsdown",
    "build:story": "storybook build --docs --output-dir storybook",
    "test": "vitest run --coverage",
    "lint": "biome check --fix src",
    "prepare": "lefthook install",
    "commit": "git add -A && git commit --no-edit",
    "squash": "bun scripts/squash.ts && git commit --no-edit --no-verify",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@chromatic-com/storybook": "^5.2.1",
    "@es-proj/utils": "^1.6.10",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tsdown/css": "^0.22.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "czg": "^1.13.1",
    "knip": "^6.14.1",
    "lefthook": "^2.1.8",
    "playwright": "^1.60.0",
    "storybook": "^10.4.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "lefthook"
  ]
}
